# ====================================================
# AUTOMATIZACIÓN WHATSAPP - CONFIGURACIÓN
# Copiar este archivo como .env y completar los valores
# ====================================================

# App
APP_NAME=AutomatizacionWhatsapp
DEBUG=False

# OpenAI (OCR de imágenes + extracción de precios)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Sheets (opcional)
# Descargar el archivo JSON de la cuenta de servicio desde Google Cloud Console
GOOGLE_APPLICATION_CREDENTIALS=./google_credentials.json
# ID de la Google Sheet (está en la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
GOOGLE_SHEET_ID=

# Base de datos PostgreSQL
# Formato: postgresql+asyncpg://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql+asyncpg://postgres:tu_password@localhost:5432/automatizacion

# Ruta donde se guardará el Excel de salida
EXCEL_OUTPUT_PATH=./output/precios.xlsx
